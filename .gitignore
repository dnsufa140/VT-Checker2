```
# Android build artifacts
build/
.gradle/
*.apk
*.aar
*.dex

# Android Studio and IDE files
.idea/
*.iml
*.iws
*.db-shm
*.db-wal

# Local configuration file (sdk path, signing keys, etc.)
local.properties

# Log files
*.log

# Temp files
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Coverage reports
coverage/
*.coverage
htmlcov/

# Python cache (if any Python files exist in project)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
```